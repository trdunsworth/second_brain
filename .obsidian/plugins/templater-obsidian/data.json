{
  "command_timeout": 120,
  "templates_folder": "Templates/scripts",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "journal",
      "template": "Templates/scripts/daily_journal_template.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "Templates/scripts/daily_log_template.md",
    "Templates/scripts/blog_idea_capture_template.md",
    "Templates/scripts/blog_post_template.md",
    "Templates/scripts/daily_mood_log_template_templater.md",
    "Templates/scripts/daily_reflection_template_templater.md",
    "Templates/scripts/habit_tracker_template_templater.md",
    "Templates/scripts/personal_measurements_template_templater.md",
    "Templates/scripts/daily_log_template_templater.md",
    "Templates/scripts/blog_idea_capture_template_templater.md"
  ],
  "startup_templates": [
    "Templates/scripts/daily_log_template.md"
  ],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [
    {
      "folder": ""
    }
  ]
}
